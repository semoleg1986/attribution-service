# attribution-service deploy profile
ATTR_DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/attribution_service
ATTR_USE_INMEMORY=0
ATTR_AUTO_CREATE_SCHEMA=0
ATTR_AUTH_ISSUER=auth_service
ATTR_AUTH_AUDIENCE=platform_clients
ATTR_AUTH_JWKS_URL=http://auth_service:8000/.well-known/jwks.json
ATTR_SERVICE_TOKEN=dev-service-token
