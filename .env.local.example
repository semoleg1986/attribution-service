# PROFILE: dev-inmemory
# ATTR_USE_INMEMORY=1
# ATTR_AUTO_CREATE_SCHEMA=0
# ATTR_AUTH_ISSUER=auth_service
# ATTR_AUTH_AUDIENCE=platform_clients
# ATTR_AUTH_JWKS_URL=http://localhost:8000/.well-known/jwks.json
# ATTR_SERVICE_TOKEN=dev-service-token

# PROFILE: dev-postgres
# ATTR_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/attribution_service
# ATTR_USE_INMEMORY=0
# ATTR_AUTO_CREATE_SCHEMA=1
# ATTR_AUTH_ISSUER=auth_service
# ATTR_AUTH_AUDIENCE=platform_clients
# ATTR_AUTH_JWKS_URL=http://localhost:8000/.well-known/jwks.json
# ATTR_SERVICE_TOKEN=dev-service-token
#
# PROFILE: tests-local-jwks
# ATTR_USE_INMEMORY=1
# ATTR_AUTH_ISSUER=auth_service
# ATTR_AUTH_AUDIENCE=platform_clients
# ATTR_AUTH_JWKS_JSON={"keys":[{"kty":"OKP","crv":"Ed25519","x":"<base64url>","alg":"EdDSA","use":"sig","kid":"test-kid"}]}
# ATTR_SERVICE_TOKEN=dev-service-token
